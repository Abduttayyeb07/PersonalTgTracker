# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- Telegram ---
# Get this from @BotFather on Telegram
BOT_TOKEN=123456:ABC-your-bot-token-here

# --- Database (Postgres) ---
# Feeds the postgres container directly (docker-compose.yml substitutes these
# into its own config). Pick your own values — don't reuse this example password.
POSTGRES_USER=tracker
POSTGRES_PASSWORD=change-me-to-something-random
POSTGRES_DB=tracker

# Local dev (`npm run dev`): use the published container port 48732 on localhost,
# with the same credentials as above. Inside docker-compose this is
# auto-overridden to postgres:5432 (the service) for the bot container.
DATABASE_URL=postgres://tracker:change-me-to-something-random@localhost:48732/tracker

# --- Behaviour ---
DEFAULT_TIMEZONE=Asia/Karachi
DEFAULT_DIGEST_HOUR=9
SCHEDULER_INTERVAL_SECONDS=30

# --- Amazon Bedrock (optional AI parsing) ---
# When ENABLE_BEDROCK_API=true, free-text quick-add is parsed by the model,
# with automatic fallback to the built-in chrono parser on any error.
# The IAM user for these keys should have ONLY bedrock:InvokeModel on the one model.
ENABLE_BEDROCK_API=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_REGION=eu-central-1
AWS_BEDROCK_MODEL=qwen.qwen3-32b-v1:0
AWS_BEDROCK_ENDPOINT_URL=

# --- Tavily (optional web search, for /watch topic digests) ---
# Free key at https://tavily.com — 1000 searches/month free tier.
# Without this set, /watch still lets you subscribe but digests won't send
# until a key is added and the bot restarted.
TAVILY_API_KEY=
WATCH_INTERVAL_DAYS=7
