# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- Telegram ---
# Get this from @BotFather on Telegram
BOT_TOKEN=123456:ABC-your-bot-token-here

# --- Database (Postgres) ---
# With docker-compose, host = "postgres" (the service name).
# For local dev outside docker, host = "localhost".
DATABASE_URL=postgres://tracker:tracker@postgres:5432/tracker

# --- Behaviour ---
DEFAULT_TIMEZONE=Asia/Kolkata
DEFAULT_DIGEST_HOUR=9
SCHEDULER_INTERVAL_SECONDS=30

# --- Amazon Bedrock (optional AI parsing) ---
# When ENABLE_BEDROCK_API=true, free-text quick-add is parsed by the model,
# with automatic fallback to the built-in chrono parser on any error.
# The IAM user for these keys should have ONLY bedrock:InvokeModel on the one model.
ENABLE_BEDROCK_API=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_REGION=eu-central-1
AWS_BEDROCK_MODEL=qwen.qwen3-32b-v1:0
AWS_BEDROCK_ENDPOINT_URL=
