{
  "name": "personal-tracker-bot",
  "version": "0.1.0",
  "description": "Personal Tracker - a multi-user Telegram bot for personal & professional task tracking with reminders and a daily digest.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.677.0",
    "chrono-node": "^2.7.7",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "grammy": "^1.30.0",
    "luxon": "^3.5.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
